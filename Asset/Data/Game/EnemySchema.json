{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"title": "EnemyData",
	"type": "object",
	"properties": {
		"id": { "type": "string" },
		"hp": {
			"type": "integer",
			"minimum": 1
		},
		"components": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"type": {
						"type": "string",
						"enum": [ "MoveComponent", "AttackComponent" ]
					},
					"speed": { "type": "number" }
				},
				"required": [ "type" ]
			}
		}
	},
	"required": [ "id", "hp", "components" ]
}